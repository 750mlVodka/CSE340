<%- include('partials/header') %>

<main class="page organizations-page">
  <div class="section-kicker">Organizations</div>
  <h1>Organizations</h1>

  <h2>Partner Organizations</h2>
  <p>Here you can find a list of organizations we partner with.</p>
  
  <ul>
    <% organizations.forEach(organization => { %>
      <li>
        <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo" style="max-width: 200px;">
        <strong><%= organization.name %></strong>: <%= organization.contact_email %>
      </li>
    <% }); %>
  </ul>
</main>

<%- include('partials/footer') %>
